table fOcorrencias
	lineageTag: c456b3ec-5ccb-4d97-adfe-1749a2b8de37

	measure 'Total Atendimentos' = COUNTROWS(fOcorrencias)
		formatString: 0
		lineageTag: 6e6428ac-1f74-4697-9a4d-65f5755d1807

	measure 'Tempo Médio Retorno (Dias)' = AVERAGE(fOcorrencias[Qtd Dias p/ Resposta])
